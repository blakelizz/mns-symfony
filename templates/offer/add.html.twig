{% extends 'base.html.twig' %}

{% block title %}Ajouter une Offre{% endblock %}

{% block body %}
<div class="container">
    <h1>Ajouter une Offre</h1>
    
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="btn btn-primary">Ajouter l'offre</button>
    {{ form_end(form) }}
    
    <a href="{{ path('offers') }}" class="btn btn-secondary">Retour à la liste</a>
</div>
{% endblock %}
